# =========================================================================
# Sports Analyzer — backend environment (EXAMPLE / template)
# Copy this file to `.env.local` at the repo root (or export these vars) and
# fill in the real values. NEVER commit real secrets.
# =========================================================================

# --- Supabase project ----------------------------------------------------
# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key (server-side ONLY — full access, keep secret).
# Supabase Dashboard -> Project Settings -> API -> service_role secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Database connection string -----------------------------------------
# Async SQLAlchemy/asyncpg URL for the Supabase Postgres instance:
#   postgresql+asyncpg://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# For purely local development without Supabase you may instead use async SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./backend/saas_local.db

# --- Stripe payment webhook pipeline (Milestone 2) -----------------------
# WEB-ONLY monetization (Apple Guideline 3.1.3(b) Multiplatform Services):
# all checkout + card management happens on Stripe-hosted web pages; the app
# only reads the resulting license entitlement.
#
# STRIPE_SECRET_KEY:        Dashboard -> Developers -> API keys -> Secret key
# STRIPE_WEBHOOK_SECRET:    from `stripe listen` (local) or the dashboard
#                           webhook endpoint's signing secret (prod)
# STRIPE_INDIVIDUAL_PRICE_ID / STRIPE_ENTERPRISE_PRICE_ID:
#                           recurring (subscription) Price IDs from the catalog
#
# Local testing forwarder:
#   stripe listen --forward-to localhost:8000/webhook/stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_INDIVIDUAL_PRICE_ID=price_your_individual_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_id

# --- Admin API key (protects /users and management routes) ----------------
# Generate a long random string. Required for:
#   * Next.js admin UI at /admin (sent as X-Admin-Key header)
#   * Streamlit admin_dashboard.py (server-side API calls)
# Set on Render for sportsanalyzer-api (and sportsanalyzer-admin if deployed).
ADMIN_API_KEY=your-long-random-admin-key

# --- Application security (Layer 3 middleware) ----------------------------
# Master switch for IP-based rate limiting (disable for local dev if needed).
RATE_LIMIT_ENABLED=true

# General API rate limit (requests per window per IP).
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Stricter limits for admin routes (mitigates API-key brute force).
RATE_LIMIT_ADMIN_REQUESTS=30
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60

# Checkout endpoint limits (mitigates Stripe session spam).
RATE_LIMIT_CHECKOUT_REQUESTS=20
RATE_LIMIT_CHECKOUT_WINDOW_SECONDS=60

# Validate endpoint limits (mitigates token enumeration).
RATE_LIMIT_VALIDATE_REQUESTS=60
RATE_LIMIT_VALIDATE_WINDOW_SECONDS=60

# Optional Redis URL for shared rate-limit counters across multiple workers.
# Requires: pip install redis
# REDIS_URL=redis://localhost:6379/0

# Maximum request body size in bytes (default 1 MB).
MAX_BODY_SIZE_BYTES=1048576

# HSTS max-age in seconds (default 1 year). Applied only over HTTPS.
HSTS_MAX_AGE_SECONDS=31536000

# Content-Security-Policy for JSON API responses.
# API_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'

# Comma-separated extra CORS origins (e.g. custom domain previews).
# CORS_EXTRA_ORIGINS=https://my-preview.example.com

# Expose /docs OpenAPI UI (leave unset in production).
# ENABLE_API_DOCS=true

# --- Streamlit admin dashboard (optional third Render service) ------------
# UI login password for admin_dashboard.py / sportsanalyzer-admin.
# Separate from ADMIN_API_KEY — gates the Streamlit page itself.
ADMIN_DASHBOARD_PASSWORD=choose-a-strong-password
